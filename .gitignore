# ─── Python ──────────────────────────────────────────────────────────────
# Bytecode caches and compiled Python; regenerated on every run.
__pycache__/
*.py[cod]
*$py.class

# Installer / editable-install metadata (created by `pip install -e .`)
*.egg-info/
*.egg
.eggs/

# Build artifacts from setup.py / pybind11 extension compilation.
# (Comments can only be on their own line in .gitignore — patterns must be alone.)
build/
dist/
# Compiled C extension shared libraries (the Python-importable .so on Linux/macOS,
# .dylib on macOS dynamic libs, .pyd on Windows).
*.so
*.dylib
*.pyd

# ─── C++ build leftovers ─────────────────────────────────────────────────
# Object files from compilation, static libraries, CMake cache.
*.o
*.obj
*.a
CMakeCache.txt
CMakeFiles/

# ─── Testing / coverage ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── Editors and OS ──────────────────────────────────────────────────────
.vscode/
.idea/
# vim swap files
*.swp
# macOS folder metadata (apologies in advance to Linux users)
.DS_Store

# ─── Environments ────────────────────────────────────────────────────────
# We distribute environment.yml; nobody should commit their personal env.
.venv/
venv/
env/

# ─── Datasets ────────────────────────────────────────────────────────────
# Demos auto-download MNIST (and future datasets) on first run. Never
# commit the actual bytes — they're regenerated on demand.
data/

# ─── Training logs ───────────────────────────────────────────────────────
# Long training runs pipe stdout/stderr to logs/. These are big and
# specific to one run — not committed. Summary tables and plots go
# into docs/demos/ instead.
logs/

# ─── cibuildwheel / PyPI publish artifacts ──────────────────────────────
# cibuildwheel dumps built wheels into wheelhouse/. Individual wheels are
# up to 10MB and specific to (os, arch, python) so they don't belong in
# the repo — CI uploads them to PyPI directly.
wheelhouse/
*.whl

# ─── Kiro internal working docs ─────────────────────────────────────
# AI steering and system prompt files — kept on disk for the IDE
# (Kiro uses them as project guidance) but never committed, since
# they contain iteration-specific working notes.
# Backups live in a separate private repo (kiro-templates).
.kiro/
docs/SYSTEM_PROMPT.md
